# --- Vercel / Netlify production ---
# Įkelkite tuos pačius VITE_* (ir kitus viešus) kintamuosius hostingo SKYDUJE:
# Vercel → Project → Settings → Environment Variables; po pakeitimo – Redeploy.

# --- Option A: Google Firebase (often feels simpler: no SQL, web console only) ---
# 1) console.firebase.google.com → Create project → Build → Firestore (start mode) + Authentication (Email/Google).
# 2) Project settings → Your apps → Web app → copy config into env below.
# 3) Firestore → Rules → paste contents of firestore.rules from this repo → Publish.
# 4) If booking page errors mention "index", deploy firestore.indexes.json or use link in error.
VITE_USE_FIREBASE=true
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Option B: Supabase (Postgres). Leave Firebase off: VITE_USE_FIREBASE=false or unset. ---
# Paste supabase/migrations/20250322120000_crm_schema.sql in SQL Editor; enable Replication.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Mokėjimai (Stripe) ---
# 1) Sukurkite Stripe paskyrą: https://dashboard.stripe.com/register
# 2) Gauk test raktus: Developers → API keys
# 3) Nustatykite webhook: Developers → Webhooks → add endpoint /webhook
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Serveris (Backend, server.cjs) ---
PORT=3001
NODE_ENV=development
# Leidžiami CORS origin'ai (per kablelį). Tuščia = localhost:3000 ir :5173. Produkcijoje —
# įrašykite savo domeną, pvz. https://mano-crm.vercel.app,bet ne naudokite *.
# CORS_ORIGINS=https://jusu-domenas.lt,http://127.0.0.1:5173

# Set to "true" to force local browser-only mode (ignores cloud).
# VITE_DEMO_MODE=false

# Google Gemini (AI chat, TTS, įžvalgos) — naudokite VITE_ arba GEMINI (žemiau)
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Alternatyva: be VITE_ — įterpiama į bundle kaip process.env.GEMINI_API_KEY (vite.config define)
# GEMINI_API_KEY=

# OpenRouter API key for AI chat assistant
VITE_OPENROUTER_API_KEY=

# Google Maps (adresas kliento formoje: Places Autocomplete + nuoroda į žemėlapį)
# Google Cloud Console → APIs → Maps JavaScript API + Places API (billing)
VITE_GOOGLE_MAPS_API_KEY=

# --- Automatinis sąskaitų siuntimas el. paštu (Resend + server.cjs) ---
# 1) https://resend.com → API raktas. 2) npm run server (arba dev:full). 3) CRM: kliento kortelėje el. paštas.
# 4) Žemiau nurodykite API adresą, jei frontendas ne localhost (produkcijoje — jūsų serverio URL).
# Siuntimas: serveris tikrina, kad gavėjo el. paštas sutaptų su įrašu DB (clients.email) — pirmiausia išsaugokite klientą.
# Su onboarding@resend.dev / be patvirtinto domeno: Resend leidžia siųsti tik į paskyroje nurodytą/emailą (pvz. klaida „testing emails to your own address“).
# Sprendimas produkcijai: https://resend.com/domains — patvirtinkite domeną, tada RESEND_FROM_EMAIL=info@jusudomenas.lt (tas pats Render .env).
# Jei CRM rodo klaidą apie domeną: tai ne CRM bugas — konfigūruokite Resend. Resend → Logs rodo tikslų atmetimo priežastį.
# Serveriui reikia SUPABASE_URL (arba VITE_SUPABASE_URL) + SUPABASE_ANON_KEY — kad JWT būtų galima patikrinti ir nuskaityti užsakymą.
# RESEND_API_KEY: įrašykite savo tikrą raktą (prasideda re_...), ne palikite pavyzdžio re_xxxxxxxxx kode.
RESEND_API_KEY=
# Siuntėjo adresas. Testui: onboarding@resend.dev. Produkcijai — patvirtinkite domeną Resend ir naudokite pvz. info@svarusdarbas.lt
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Švarus Darbas
# Arba vienu lauku: RESEND_FROM_EMAIL=Švarus darbas <info@svarusdarbas.lt>
# VITE_INVOICE_API_BASE_URL=https://jusu-api.example.com
# CRM Vercel + API kitame serveryje: server.cjs .env → FRONTEND_URL=https://jusu-crm.vercel.app (CORS)
# Arba kelios kilmės: CORS_ORIGINS=https://a.lt,https://b.vercel.app

# --- Email (alternatyva / seniau planuota SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@svarusdarbas.lt

# --- SMS (būsimam) ---
# Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
