rules_version = '2';
// Paste into Firebase Console → Firestore Database → Rules → Publish
// Note: settings are readable by anyone with the link (needed for public booking prices).
// Do not store secrets in settings documents.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function hasSettingsDoc(ownerUid) {
      return exists(/databases/$(database)/documents/settings/$(ownerUid));
    }

    match /settings/{userId} {
      allow read: if true;
      allow write: if owns(userId);
    }

    match /clients/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if (signedIn() && request.resource.data.uid == request.auth.uid)
        || (!signedIn()
            && request.resource.data.keys().hasAll(['uid', 'name', 'phone', 'address', 'buildingType', 'createdAt'])
            && hasSettingsDoc(request.resource.data.uid));
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /orders/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if (signedIn() && request.resource.data.uid == request.auth.uid)
        || (!signedIn()
            && request.resource.data.keys().hasAll(['uid', 'clientId', 'clientName', 'date', 'time', 'windowCount', 'floor', 'totalPrice', 'status', 'createdAt'])
            && hasSettingsDoc(request.resource.data.uid));
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /expenses/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /employees/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /inventory/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /memories/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }
  }
}
