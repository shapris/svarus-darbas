{
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-store, must-revalidate" }]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/((?:vendor|app|index)-.*\\.(?:js|css))", "dest": "/assets/$1" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
